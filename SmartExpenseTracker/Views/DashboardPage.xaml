<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartExpenseTracker.ViewModels"
             xmlns:charts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="SmartExpenseTracker.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <Style x:Key="CardFrame" TargetType="Frame">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="HasShadow" Value="True" />
            <Setter Property="BackgroundColor" Value="White" />
        </Style>
    </ContentPage.Resources>

    <RefreshView Command="{Binding LoadCommand}"
                 IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16">

                <!-- Today Card -->
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout>
                        <Label Text="Today's Spending" FontSize="14" TextColor="Gray" />
                        <Label Text="{Binding TodayTotal, StringFormat='₹{0:N2}'}"
                               FontSize="28" FontAttributes="Bold" TextColor="#2E75B6" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Month Card -->
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout>
                        <Label Text="This Month" FontSize="14" TextColor="Gray" />
                        <Label Text="{Binding MonthTotal, StringFormat='₹{0:N2}'}"
                               FontSize="28" FontAttributes="Bold" TextColor="#E74C3C" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Budget Summary Card -->
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Monthly Budget" FontSize="14" TextColor="Gray" />
                        <Label Text="{Binding BudgetLimit, StringFormat='Limit: ₹{0:N2}'}" />
                        <Label Text="{Binding BudgetRemaining, StringFormat='Remaining: ₹{0:N2}'}" />
                        <ProgressBar Progress="{Binding BudgetPercent, Converter={StaticResource PctConverter}}"
                                     ProgressColor="#2E75B6" />
                        <Label Text="{Binding BudgetPercent, StringFormat='{0:F1}% used'}"
                               HorizontalOptions="End" FontSize="12" TextColor="Gray" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Category Summary -->
                <Label Text="Category Breakdown" FontSize="16" FontAttributes="Bold"
                       Margin="8,12,8,4" />
                <CollectionView ItemsSource="{Binding CategorySummaries}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategorySummary">
                            <Frame Style="{StaticResource CardFrame}" Margin="8,2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Category}" FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Amount, StringFormat='₹{0:N2}'}"
                                           FontAttributes="Bold" TextColor="#2E75B6" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Floating Action Button (Add Expense) -->
                <Button Text="+ Add Expense"
                        Clicked="OnAddExpenseTapped"
                        BackgroundColor="#2E75B6" TextColor="White"
                        CornerRadius="28" HeightRequest="56" Margin="0,16" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
