<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartExpenseTracker.ViewModels"
             x:Class="SmartExpenseTracker.Views.PINLockPage"
             x:DataType="vm:PINViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout VerticalOptions="Center" Padding="40" Spacing="20">

        <Image Source="lock.png" HeightRequest="80" />
        <Label Text="Enter your PIN" FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Entry Placeholder="●●●●" MaxLength="4" Keyboard="Numeric"
               IsPassword="True" Text="{Binding Pin}"
               FontSize="24" HorizontalTextAlignment="Center" />

        <Label Text="{Binding ErrorMessage}" TextColor="Red"
               HorizontalOptions="Center"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNullConverter}}" />

        <Button Text="Unlock" Command="{Binding SubmitCommand}"
                BackgroundColor="#2E75B6" TextColor="White"
                CornerRadius="12" HeightRequest="52" />
    </VerticalStackLayout>
</ContentPage>
