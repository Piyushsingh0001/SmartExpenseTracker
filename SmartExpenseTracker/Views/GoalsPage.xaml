<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartExpenseTracker.ViewModels"
             xmlns:models="clr-namespace:SmartExpenseTracker.Models"
             x:Class="SmartExpenseTracker.Views.GoalsPage"
             x:DataType="vm:GoalsViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto,*">

        <!-- Add Goal Form -->
        <Frame Grid.Row="0" Margin="12" Padding="16" CornerRadius="12" HasShadow="True">
            <VerticalStackLayout Spacing="8">
                <Label Text="Add New Goal" FontAttributes="Bold" FontSize="16" />
                <Entry Placeholder="Goal Name" Text="{Binding GoalName}" />
                <Entry Placeholder="Target Amount (₹)" Keyboard="Numeric"
                       Text="{Binding TargetAmount}" />
                <Entry Placeholder="Already Saved (₹)" Keyboard="Numeric"
                       Text="{Binding SavedAmount}" />
                <DatePicker Date="{Binding Deadline}" />
                <Button Text="Add Goal" Command="{Binding AddGoalCommand}"
                        BackgroundColor="#27AE60" TextColor="White" CornerRadius="8" />
            </VerticalStackLayout>
        </Frame>

        <!-- Goals List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Goals}"
                        EmptyView="No goals yet. Add one above!">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Goal">
                    <Frame Margin="12,4" Padding="16" CornerRadius="12" HasShadow="True">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <Label Grid.Row="0" Text="{Binding GoalName}"
                                   FontAttributes="Bold" FontSize="16" />
                            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,4">
                                <Label Text="{Binding SavedAmount, StringFormat='Saved: ₹{0:N0}'}" />
                                <Label Grid.Column="1"
                                       Text="{Binding TargetAmount, StringFormat='Target: ₹{0:N0}'}"
                                       HorizontalOptions="End" />
                            </Grid>
                            <ProgressBar Grid.Row="2"
                                         Progress="{Binding ProgressPercentage, Converter={StaticResource PctConverter}}"
                                         ProgressColor="#27AE60" />
                            <Label Text="{Binding ProgressPercentage, StringFormat='{0:F1}%'}"
                                   HorizontalOptions="End" FontSize="11" TextColor="Gray" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
